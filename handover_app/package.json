{
  "name": "handover",
  "private": true,
  "version": "1.0.3",
  "description": "Multi-terminal AI CLI orchestration with Docker sandboxes and project handoffs.",
  "author": "Handover",
  "type": "module",
  "scripts": {
    "dev": "vite --logLevel warn",
    "dev:tauri": "bash scripts/dev-tauri.sh",
    "build:backend": "cd ../handover_rust && cargo build --release",
    "build:backend:debug": "cd ../handover_rust && cargo build",
    "prepare:sidecar": "bash scripts/prepare-backend-sidecar.sh debug",
    "prepare:sidecar:release": "bash scripts/prepare-backend-sidecar.sh release",
    "icons": "python3 scripts/generate-icons.py",
    "build:docker-base": "bash ../handover/docker/build-base.sh",
    "build": "vite build",
    "build:tauri": "npm run icons && npm run build:backend && npm run prepare:sidecar:release && tauri build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.9.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
