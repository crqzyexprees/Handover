{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Handover",
  "version": "1.0.3",
  "identifier": "com.handover.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Handover",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "externalBin": ["binaries/handover-backend"]
  }
}
