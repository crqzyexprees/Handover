{
  "name": "handover",
  "private": true,
  "version": "0.0.0",
  "description": "Multi-terminal AI CLI orchestration with Docker sandboxes and project handoffs.",
  "author": "Handover",
  "type": "module",
  "packageManager": "traversal@0.0.0",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && HANDOVER_BACKEND=rust VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:electron:python": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:backend": "cd ../handover_rust && cargo build --release",
    "build:backend:python": "cd backend && ./venv/bin/pyinstaller handover-backend.spec",
    "build": "vite build && electron-builder --config electron-builder.config.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.16.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
